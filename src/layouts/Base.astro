---
import { SITE, INTEGRATIONS } from "../config";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  isTool?: boolean;
}
const { title, description, isTool = false } = Astro.props;
const fullTitle = title === SITE.name ? `${SITE.name} — ${SITE.tagline}` : `${title} — ${SITE.name}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, SITE.url).href} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@600;700;800&family=Instrument+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    {isTool && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebApplication",
        name: title,
        description,
        url: new URL(Astro.url.pathname, SITE.url).href,
        applicationCategory: "UtilityApplication",
        operatingSystem: "Any",
        offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
        browserRequirements: "Runs entirely in the browser. No data is uploaded.",
      })} />
    )}
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a class="brand" href="/">
          <span class="brand-mark">0</span>
          {SITE.name}
        </a>
        <nav class="site-nav">
          <a href="/#tools">All tools</a>
          <a href="/about/">Why local-only</a>
          {INTEGRATIONS.donateUrl && (
            <a href={INTEGRATIONS.donateUrl} rel="noopener" target="_blank">Support this site ♥</a>
          )}
        </nav>
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <span>© {new Date().getFullYear()} {SITE.name}. Every tool runs in your browser.</span>
        <span>
          No accounts. No uploads. No tracking cookies.
          {INTEGRATIONS.cloudflareAnalyticsToken && " Anonymous pageviews counted — never your content."}
        </span>
      </div>
    </footer>

    {INTEGRATIONS.cloudflareAnalyticsToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={JSON.stringify({ token: INTEGRATIONS.cloudflareAnalyticsToken })}
      />
    )}
  </body>
</html>
