---
import Base from "../../layouts/Base.astro";
import SilenceBadge from "../../components/SilenceBadge.astro";
import CarbonAd from "../../components/CarbonAd.astro";
---
<Base
  title="Favicon Generator"
  description="Generate a complete favicon package from text, an emoji, or an image — favicon.ico, PNG sizes, apple-touch-icon, and web manifest. 100% in your browser, nothing uploaded."
  isTool
>
  <div class="tool-head">
    <h1>Favicon Generator</h1>
    <p class="lede">
      Turn text, an emoji, or an image into a complete favicon package:
      favicon.ico, every PNG size, apple-touch-icon, and a web manifest.
      Preview it in a real browser tab before you download.
    </p>
    <SilenceBadge />
  </div>

  <div class="tool-grid">
    <div class="panel">
      <div class="field">
        <label for="mode">Source</label>
        <select id="mode">
          <option value="text">Text</option>
          <option value="emoji">Emoji</option>
          <option value="image">Image</option>
        </select>
      </div>

      <div id="text-controls">
        <div class="field">
          <label for="txt">Characters (1–3 work best)</label>
          <input type="text" id="txt" value="Z" maxlength="4" />
        </div>
        <div class="field">
          <label for="font">Font</label>
          <select id="font">
            <option value="Bricolage Grotesque">Bricolage Grotesque</option>
            <option value="Instrument Sans">Instrument Sans</option>
            <option value="IBM Plex Mono">IBM Plex Mono</option>
            <option value="Georgia">Georgia (serif)</option>
            <option value="Arial Black">Arial Black</option>
          </select>
        </div>
        <div class="field">
          <label for="fg">Text color</label>
          <input type="color" id="fg" value="#ffffff" />
        </div>
      </div>

      <div id="emoji-controls" hidden>
        <div class="field">
          <label for="emo">Emoji</label>
          <input type="text" id="emo" value="🚀" maxlength="4" />
        </div>
      </div>

      <div id="image-controls" hidden>
        <div class="field">
          <label for="img">Image (PNG, JPEG, SVG — square works best)</label>
          <input type="file" id="img" accept="image/*" />
        </div>
      </div>

      <div class="field">
        <label for="bg">Background color</label>
        <input type="color" id="bg" value="#2742f5" />
      </div>
      <div class="field">
        <label for="shape">Background shape</label>
        <select id="shape">
          <option value="square">Square</option>
          <option value="rounded" selected>Rounded</option>
          <option value="circle">Circle</option>
          <option value="none">Transparent</option>
        </select>
      </div>

      <button class="btn" id="dl">Download favicon package (.zip)</button>
    </div>

    <div class="panel">
      <p style="font-size:0.85rem;font-weight:600;color:var(--ink-soft);margin:0 0 10px">Live preview</p>

      <!-- Browser tab mockups: the thing favicon.io doesn't give you -->
      <div class="tabmock light">
        <canvas class="tab-ico" width="32" height="32"></canvas>
        <span>Your site — light tab</span>
      </div>
      <div class="tabmock dark">
        <canvas class="tab-ico" width="32" height="32"></canvas>
        <span>Your site — dark tab</span>
      </div>

      <p style="font-size:0.85rem;font-weight:600;color:var(--ink-soft);margin:18px 0 10px">All sizes</p>
      <div class="size-row">
        <figure><canvas id="c16" width="16" height="16"></canvas><figcaption>16</figcaption></figure>
        <figure><canvas id="c32" width="32" height="32"></canvas><figcaption>32</figcaption></figure>
        <figure><canvas id="c48" width="48" height="48"></canvas><figcaption>48</figcaption></figure>
        <figure><canvas id="c180" width="180" height="180"></canvas><figcaption>180</figcaption></figure>
      </div>

      <p style="font-size:0.85rem;font-weight:600;color:var(--ink-soft);margin:18px 0 6px">Paste into your &lt;head&gt;</p>
      <pre class="snippet" id="snippet"></pre>
      <button class="btn secondary" id="copy">Copy snippet</button>
    </div>
  </div>

  <CarbonAd />

  <article class="seo-prose">
    <h2>How this favicon generator works</h2>
    <p>
      Everything happens in your browser with the HTML Canvas API. Your text,
      emoji, or uploaded image is rendered locally at 16, 32, 48, 180, 192, and
      512 pixels, packed into a standards-compliant favicon.ico plus individual
      PNGs and a web manifest, then zipped on your device. There is no upload
      step, which also means there is nothing for anyone to log, scan, or keep.
    </p>
    <h2>What's in the download</h2>
    <p>
      favicon.ico (16/32/48 multi-size), favicon-16x16.png, favicon-32x32.png,
      apple-touch-icon.png (180), android-chrome-192x192.png,
      android-chrome-512x512.png, and site.webmanifest — the complete set
      Google, Apple, and Android expect, with the exact HTML snippet to match.
    </p>
  </article>

  <style>
    .tabmock {
      display: flex; align-items: center; gap: 10px;
      border-radius: 10px 10px 0 0;
      padding: 9px 14px; font-size: 0.85rem;
      margin-bottom: 8px; border: 1px solid var(--line);
    }
    .tabmock.light { background: #f1f3f4; color: #202124; }
    .tabmock.dark { background: #202124; color: #e8eaed; border-color: #202124; }
    .tabmock canvas { width: 16px; height: 16px; }
    .size-row { display: flex; gap: 18px; align-items: flex-end; }
    .size-row figure { margin: 0; text-align: center; }
    .size-row figcaption { font-family: var(--font-mono); font-size: 0.7rem; color: var(--ink-soft); margin-top: 4px; }
    .size-row canvas { border: 1px solid var(--line); border-radius: 4px; background:
      repeating-conic-gradient(#f0f0f0 0% 25%, #fff 0% 50%) 0 0 / 12px 12px; }
    #c180 { width: 64px; height: 64px; }
    .snippet {
      background: #16202e; color: #d7e3f4; font-family: var(--font-mono);
      font-size: 0.72rem; padding: 12px; border-radius: 8px;
      overflow-x: auto; white-space: pre; margin: 0 0 10px;
    }
  </style>

  <script>
    import { zipSync } from "fflate";

    const $ = (id: string) => document.getElementById(id) as any;
    const SIZES = [16, 32, 48, 180, 192, 512];
    let uploadedImg: HTMLImageElement | null = null;

    function drawIcon(size: number): HTMLCanvasElement {
      const c = document.createElement("canvas");
      c.width = c.height = size;
      const ctx = c.getContext("2d")!;
      const shape = $("shape").value;
      const mode = $("mode").value;

      // background
      if (shape !== "none") {
        ctx.fillStyle = $("bg").value;
        if (shape === "circle") {
          ctx.beginPath();
          ctx.arc(size / 2, size / 2, size / 2, 0, Math.PI * 2);
          ctx.fill();
        } else {
          const r = shape === "rounded" ? size * 0.2 : 0;
          ctx.beginPath();
          ctx.roundRect(0, 0, size, size, r);
          ctx.fill();
        }
      }

      // foreground
      if (mode === "image" && uploadedImg) {
        const pad = shape === "none" ? 0 : size * 0.1;
        const box = size - pad * 2;
        const ratio = Math.min(box / uploadedImg.width, box / uploadedImg.height);
        const w = uploadedImg.width * ratio, h = uploadedImg.height * ratio;
        ctx.drawImage(uploadedImg, (size - w) / 2, (size - h) / 2, w, h);
      } else {
        const text = mode === "emoji" ? ($("emo").value || "🚀") : ($("txt").value || "Z");
        const font = mode === "emoji" ? "system-ui" : $("font").value;
        ctx.fillStyle = $("fg").value;
        ctx.textAlign = "center";
        ctx.textBaseline = "middle";
        let fs = size * (mode === "emoji" ? 0.74 : 0.62);
        ctx.font = `700 ${fs}px ${font}`;
        // shrink to fit
        while (ctx.measureText(text).width > size * 0.86 && fs > 4) {
          fs *= 0.94;
          ctx.font = `700 ${fs}px ${font}`;
        }
        ctx.fillText(text, size / 2, size / 2 + size * 0.02);
      }
      return c;
    }

    function render() {
      for (const s of [16, 32, 48, 180]) {
        const target = $(`c${s}`) as HTMLCanvasElement;
        target.getContext("2d")!.clearRect(0, 0, s, s);
        target.getContext("2d")!.drawImage(drawIcon(s), 0, 0);
      }
      document.querySelectorAll<HTMLCanvasElement>(".tab-ico").forEach((t) => {
        t.getContext("2d")!.clearRect(0, 0, 32, 32);
        t.getContext("2d")!.drawImage(drawIcon(32), 0, 0);
      });
      $("snippet").textContent = [
        '<link rel="icon" href="/favicon.ico" sizes="48x48">',
        '<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">',
        '<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">',
        '<link rel="apple-touch-icon" href="/apple-touch-icon.png">',
        '<link rel="manifest" href="/site.webmanifest">',
      ].join("\n");
    }

    async function canvasPng(c: HTMLCanvasElement): Promise<Uint8Array> {
      const blob: Blob = await new Promise((res) => c.toBlob((b) => res(b!), "image/png"));
      return new Uint8Array(await blob.arrayBuffer());
    }

    // Build a favicon.ico containing PNG-encoded 16/32/48 images.
    function buildIco(pngs: { size: number; data: Uint8Array }[]): Uint8Array {
      const headerSize = 6 + 16 * pngs.length;
      let total = headerSize;
      for (const p of pngs) total += p.data.length;
      const out = new Uint8Array(total);
      const dv = new DataView(out.buffer);
      dv.setUint16(0, 0, true);            // reserved
      dv.setUint16(2, 1, true);            // type: icon
      dv.setUint16(4, pngs.length, true);  // count
      let offset = headerSize;
      pngs.forEach((p, i) => {
        const e = 6 + i * 16;
        out[e] = p.size === 256 ? 0 : p.size;     // width
        out[e + 1] = p.size === 256 ? 0 : p.size; // height
        out[e + 2] = 0;                            // palette
        out[e + 3] = 0;                            // reserved
        dv.setUint16(e + 4, 1, true);              // planes
        dv.setUint16(e + 6, 32, true);             // bpp
        dv.setUint32(e + 8, p.data.length, true);  // bytes
        dv.setUint32(e + 12, offset, true);        // offset
        out.set(p.data, offset);
        offset += p.data.length;
      });
      return out;
    }

    async function download() {
      const btn = $("dl");
      btn.disabled = true;
      btn.textContent = "Building…";
      try {
        const pngs: Record<number, Uint8Array> = {};
        for (const s of SIZES) pngs[s] = await canvasPng(drawIcon(s));
        const ico = buildIco([16, 32, 48].map((s) => ({ size: s, data: pngs[s] })));
        const manifest = JSON.stringify({
          name: "", short_name: "",
          icons: [
            { src: "/android-chrome-192x192.png", sizes: "192x192", type: "image/png" },
            { src: "/android-chrome-512x512.png", sizes: "512x512", type: "image/png" },
          ],
          theme_color: $("bg").value, background_color: $("bg").value, display: "standalone",
        }, null, 2);
        const zipped = zipSync({
          "favicon.ico": ico,
          "favicon-16x16.png": pngs[16],
          "favicon-32x32.png": pngs[32],
          "apple-touch-icon.png": pngs[180],
          "android-chrome-192x192.png": pngs[192],
          "android-chrome-512x512.png": pngs[512],
          "site.webmanifest": new TextEncoder().encode(manifest),
          "README.txt": new TextEncoder().encode(
            "Place all files in your site root, then paste the snippet from the generator into your <head>.\n"
          ),
        });
        const url = URL.createObjectURL(new Blob([zipped.buffer as ArrayBuffer], { type: "application/zip" }));
        const a = document.createElement("a");
        a.href = url;
        a.download = "favicon-package.zip";
        a.click();
        URL.revokeObjectURL(url);
      } finally {
        btn.disabled = false;
        btn.textContent = "Download favicon package (.zip)";
      }
    }

    // wire up
    $("mode").addEventListener("change", () => {
      const m = $("mode").value;
      $("text-controls").hidden = m !== "text";
      $("emoji-controls").hidden = m !== "emoji";
      $("image-controls").hidden = m !== "image";
      render();
    });
    $("img").addEventListener("change", (e: Event) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (!file) return;
      const img = new Image();
      img.onload = () => { uploadedImg = img; render(); };
      img.src = URL.createObjectURL(file);
    });
    for (const id of ["txt", "font", "fg", "bg", "shape", "emo"]) {
      $(id).addEventListener("input", render);
    }
    $("dl").addEventListener("click", download);
    $("copy").addEventListener("click", async () => {
      await navigator.clipboard.writeText($("snippet").textContent || "");
      $("copy").textContent = "Copied";
      setTimeout(() => ($("copy").textContent = "Copy snippet"), 1500);
    });

    document.fonts?.ready.then(render);
    render();
  </script>
</Base>
